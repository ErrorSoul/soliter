      free_slot1 = {pos = go.get_position('free_slot1'), dragon = nil, is_empty = true },
      free_slot2 = {pos = go.get_position('free_slot2'), dragon = nil, is_empty = true },
      free_slot3 = {pos = go.get_position('free_slot3'), dragon = nil, is_empty = true },
   }
end

